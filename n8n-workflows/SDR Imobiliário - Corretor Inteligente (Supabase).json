      "id": "12ab6117-7540-4dd2-8cda-ce7e11b95484",
      "name": "Webhook Out → SaaS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3200, -160]
    },
    {
      "parameters": {
        "jsCode": "const acao = $('Parse AI').first().json.acao || 'continuar';\nconst statusAnterior = $('Parse AI').first().json.statusAnterior || 'novo';\n\nconst jaQualificado = statusAnterior === 'Quente' || statusAnterior === 'Agendou Visita';\nconst acaoQualifica = acao === 'qualificado' || acao === 'agendar';\n\nreturn [{ json: {\n  deveNotificar: acaoQualifica && !jaQualificado,\n  acao,\n  nome: $('Parse AI').first().json.nome || 'Não informado',\n  phone: $('Parse AI').first().json.phone,\n  orcamento: $('Parse AI').first().json.orcamento || 'Não informado',\n  bairro: $('Parse AI').first().json.bairro || 'Não informado',\n  tipo_imovel: $('Parse AI').first().json.tipo_imovel || 'Não informado',\n  finalidade: $('Parse AI').first().json.finalidade || 'Não informado',\n  instanceName: $('Normalizar').first().json.instanceName\n} }];"
      },
