    {
      "parameters": {},
      "id": "b1c2d3e4-f5a6-7890-bcde-f12345678901",
      "name": "Aguardar Buscas",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [2080, -160]
