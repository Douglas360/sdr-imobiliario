# Variáveis de Ambiente — SDR Imobiliário

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...  # Usado apenas no servidor (webhook)

# Evolution API
EVOLUTION_API_URL=http://SEU_IP:8080
EVOLUTION_API_KEY=SUA_CHAVE_GLOBAL_DA_EVOLUTION

# n8n Webhook Security
N8N_WEBHOOK_SECRET=gere-um-token-secreto-aqui  # ex: openssl rand -hex 32

# URL do Webhook do seu N8N (Ex: https://n8n.sua-empresa.com/webhook/whatsapp-corretor)
# Opcional: Se preenchida, o SaaS tentará configurar este webhook automaticamente 
# na Evolution API toda vez que uma nova imobiliária conectar o WhatsApp.
N8N_WEBHOOK_URL=
